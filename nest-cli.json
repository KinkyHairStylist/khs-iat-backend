{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "**/*.ejs", "outDir": "./dist/src" }
    ],
    "watchAssets": true
  }
}
