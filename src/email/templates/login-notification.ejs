<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Security alert</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">New sign-in to your account</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= userName %>,</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">
  We noticed a successful sign-in to your Kinky Hairstylist account at <strong><%= timestamp %></strong>.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px 0;">
  <tr>
    <td style="background-color:#FEF2F2; border:1px solid #FBD5D5; border-radius:12px; padding:20px;">
      <p style="margin:0; font-size:14px; line-height:1.6; color:#52525b;">
        If this was you, no action is needed. If you don't recognise this sign-in, please <a href="mailto:support@kinkyhairstylists.com" style="color:#ED3131;">contact support</a> immediately.
      </p>
    </td>
  </tr>
</table>

<p style="margin:0 0 32px 0; font-size:13px; line-height:1.6; color:#a1a1aa;">
  This is an automated security notification &mdash; please don't reply directly to this email.
</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
