<%- include('layouts/head') %>
<% if (action === 'payment') { %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Payment confirmed</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your membership is active</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Thank you for subscribing to the <strong><%= planName %></strong> plan. Your payment of <strong>$<%= amount %></strong> has been received successfully.</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">Your next billing date is <strong><%= nextBillingDate %></strong>.</p>
<% } else if (action === 'upgrade') { %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Plan updated</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your membership has been upgraded</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">You've been upgraded from <strong><%= oldPlanName %></strong> to <strong><%= planName %></strong>.</p>
<% if (amount) { %><p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Prorated charge: <strong>$<%= amount %></strong>.</p><% } %>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">Your new renewal date is <strong><%= nextBillingDate %></strong>.</p>
<% } else if (action === 'cancelled') { %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Membership cancelled</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your membership has been cancelled</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Your <strong><%= planName %></strong> membership was cancelled on <strong><%= cancelledDate %></strong> and is effective immediately.</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">If you'd like to resubscribe in the future, you can do so from your account settings at any time.</p>
<% } %>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>/customer/membership" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">View My Membership</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<p style="margin:0 0 4px 0; font-size:13px; line-height:1.6; color:#a1a1aa;">
  Need help? Contact our support team.
</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
