<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Refund request</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your refund request has been received</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">We've received your refund request for <strong><%= currency %><%= amount %></strong>. Here's a summary:</p>
<table style="margin:0 0 24px 0; width:100%; border-collapse:collapse;" cellpadding="8" cellspacing="0">
  <tr><td style="font-size:14px; color:#52525b; border-bottom:1px solid #e4e4e7;">Reference</td><td style="font-size:14px; font-weight:600; color:#18181b; border-bottom:1px solid #e4e4e7;"><%= reference %></td></tr>
  <tr><td style="font-size:14px; color:#52525b; border-bottom:1px solid #e4e4e7;">Amount</td><td style="font-size:14px; font-weight:600; color:#18181b; border-bottom:1px solid #e4e4e7;"><%= currency %><%= amount %></td></tr>
  <tr><td style="font-size:14px; color:#52525b; border-bottom:1px solid #e4e4e7;">Reason</td><td style="font-size:14px; font-weight:600; color:#18181b; border-bottom:1px solid #e4e4e7;"><%= reason %></td></tr>
  <tr><td style="font-size:14px; color:#52525b; border-bottom:1px solid #e4e4e7;">Status</td><td style="font-size:14px; font-weight:600; color:#18181b; border-bottom:1px solid #e4e4e7;">Under review</td></tr>
</table>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">Our team will review your request and get back to you within 3–5 business days. You don't need to do anything else at this time.</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>/customer/transactions" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">View My Transactions</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<p style="margin:0 0 4px 0; font-size:13px; line-height:1.6; color:#a1a1aa;">
  Need help? Contact our support team.
</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
