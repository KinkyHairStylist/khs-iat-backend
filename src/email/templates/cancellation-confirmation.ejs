<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Appointment cancelled</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your appointment has been cancelled</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">
  Your appointment at <strong><%= businessName %></strong> for <strong><%= serviceName %></strong> on <strong><%= date %></strong> at <strong><%= time %></strong> has been cancelled as requested.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">Book a New Appointment</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 32px 0; font-size:13px; line-height:1.6; color:#a1a1aa;">
  If you'd like to rebook, simply visit our website. We'd love to have you back!
</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
