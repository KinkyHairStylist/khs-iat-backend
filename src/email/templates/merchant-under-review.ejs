<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Profile submitted</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your merchant profile is under review</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= businessName %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Thanks for submitting your merchant profile. We've received your application and it's now <strong>under review</strong>.</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Our team typically reviews new merchant profiles within <strong>24&ndash;48 hours</strong>. You'll receive another email as soon as your account is verified and your dashboard is unlocked.</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">No action is needed from you right now &mdash; we'll be in touch soon.</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>/merchant/dashboard" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">Go to Dashboard</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<%- include('layouts/foot', { frontendUrl, year }) %>
