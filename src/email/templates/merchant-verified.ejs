<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Approved</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Welcome to your verified merchant dashboard</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= businessName %>,</p>
<p style="margin:0 0 8px 0; font-size:15px; line-height:1.6; color:#52525b;">Congratulations &mdash; your merchant profile has been <strong>verified</strong>! Your dashboard is now unlocked and you're ready to start accepting bookings.</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">Set up your services, manage your schedule, and start connecting with customers on Kinky Hairstylist.</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>/merchant/dashboard" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">Open My Dashboard</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<%- include('layouts/foot', { frontendUrl, year }) %>
