<%- include('layouts/head') %>
<p style="margin:0 0 4px 0; font-size:13px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; color:#ED3131;">Appointment confirmed</p>
<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; color:#18181b; line-height:1.3;">Your appointment is confirmed</h1>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <%= name %>,</p>
<p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#52525b;">
  Your appointment at <strong><%= businessName %></strong> for <strong><%= serviceName %></strong> on <strong><%= date %></strong> at <strong><%= time %></strong> has been confirmed.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ED3131; border-radius:999px;">
            <a href="<%= frontendUrl %>/customer/appointment/booking-management" style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">View My Bookings</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<p style="margin:0 0 4px 0; font-size:13px; line-height:1.6; color:#a1a1aa;">
  Need to reschedule or cancel? Visit your bookings page.
</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
