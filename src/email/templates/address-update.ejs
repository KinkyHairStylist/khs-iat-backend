<%- include('layouts/head') %>
<h2 style="margin: 0 0 8px; color: #B91C1C;">Address <%= action === 'added' ? 'Added' : 'Updated' %></h2>
<p style="margin:0 0 16px 0; font-size:15px; line-height:1.6; color:#52525b;">Hi <strong><%= name %></strong>, your address has been <%= action %>:</p>
<table style="margin:16px 0; width:100%; border-collapse:collapse;" role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="padding:16px; background:#f4f4f5; border-radius:8px; font-size:14px; line-height:1.6; color:#52525b;">
      <strong>Type:</strong> <%= addressType %><br>
      <strong>Address:</strong> <%= fullAddress %>
    </td>
  </tr>
</table>
<p style="margin:24px 0 0 0; font-size:14px; line-height:1.6; color:#71717a;">If you did not make this change, please <a href="<%= frontendUrl %>/customer/help" style="color:#ED3131;">contact support</a> immediately.</p>
<%- include('layouts/foot', { frontendUrl, year }) %>
