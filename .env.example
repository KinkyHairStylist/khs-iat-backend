# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
NODE_ENV=development

# ============================================
# JWT TOKENS
# ============================================
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# ============================================
# SESSION
# ============================================
SESSION_SECRET=your_session_secret_key_here

# ============================================
# DATABASE
# ============================================
# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DATABASE=kinky_hair_stylist

# ============================================
# FRONTEND URLS
# ============================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000/

# ============================================
# SENDGRID EMAIL
# ============================================
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Kinky Hair Stylist

# ============================================
# PAYPAL
# ============================================
PAYPAL_SANDBOX_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_SECRET_KEY=your_paypal_secret_key
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# ============================================
# PAYSTACK
# ============================================
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_BASE_URL=https://api.paystack.co

# ============================================
# CLOUDINARY (User Uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# CLOUDINARY (Business Uploads)
# ============================================
BUSINESS_CLOUDINARY_CLOUD_NAME=your_business_cloudinary_cloud_name
BUSINESS_CLOUDINARY_API_KEY=your_business_cloudinary_api_key
BUSINESS_CLOUDINARY_API_SECRET=your_business_cloudinary_api_secret

# ============================================
# TWILIO (SMS Verification)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid
PROJECT_NAME=Kinky Hair Stylist

# ============================================
# GOOGLE CALENDAR INTEGRATION
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/integration/google-calendar/callback

# ============================================
# MAILCHIMP INTEGRATION
# ============================================
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_AUDIENCE_ID=your_mailchimp_audience_id

# ============================================
# ZOHO BOOKS INTEGRATION
# ============================================
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8080/api/integration/zoho-books/callback

# ============================================
# OPTIONAL: LEGACY EMAIL (Gmail)
# ============================================
# EMAIL_USER=your_gmail_address
# EMAIL_PASS=your_gmail_app_password

# ============================================
# OPTIONAL: MONGODB (Legacy)
# ============================================
# MONGODB_URI=mongodb://localhost:27017/kinky_hair_stylist
